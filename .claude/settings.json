{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",

  "model": "sonnet",

  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(cat *)",
      "Bash(node -v)",
      "Bash(npm -v)"
    ],

    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(secrets/**)",
      "Bash(rm -rf /)",
      "Bash(curl *)"
    ]
  }
}
